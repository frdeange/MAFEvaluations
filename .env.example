# ==============================================================================
# MAFEvaluations - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.

# Provider selection: "foundry" (default) or "openai"
EVAL_PROVIDER=foundry

# --- Azure AI Foundry (required for Foundry provider, evals, red teaming) ---
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com
FOUNDRY_MODEL=gpt-4o

# --- OpenAI (required for OpenAI provider) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Benchmarks (optional) ---
# HF_TOKEN=hf_...          # Hugging Face token for GAIA benchmark
# TAU2_DATA_DIR=data        # Path to TAU2 benchmark data
