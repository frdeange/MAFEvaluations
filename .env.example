# ==============================================================================
# MAFEvaluations - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.

# Provider selection: "foundry" (default) or "openai"
EVAL_PROVIDER=foundry

# --- Azure AI Foundry (required for Foundry provider, evals, red teaming) ---
FOUNDRY_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com
FOUNDRY_MODEL=gpt-4o

# --- Demo A: evaluate_foundry_target (optional) ---
# Set the name of an Azure AI Agent already registered in your Foundry
# project to run evaluations/12_foundry_target_eval end-to-end.
# When unset, the demo runs in documentation mode.
# FOUNDRY_TARGET_AGENT_NAME=
# FOUNDRY_TARGET_TYPE=azure_ai_agent

# --- OpenAI (required for OpenAI provider) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Benchmarks (optional) ---
# HF_TOKEN=hf_...          # Hugging Face token for GAIA benchmark
